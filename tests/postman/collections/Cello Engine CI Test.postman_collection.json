{
	"info": {
		"name": "Cello Engine CI Test",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Register User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"if (pm.response.code === 201) {",
							"    var jsonData = pm.response.json();",
							"    pm.environment.set(\"org_id\", jsonData.data.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n\t\"email\": \"foo@email.com\",\n\t\"password\": \"foo\",\n\t\"org_name\": \"org1.foo.com\",\n\t\"agent_url\": \"http://cello-hyperledger-fabric-agent:8080/api/v1/\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v1/register",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"register"
					]
				},
				"description": "Register new user with organization"
			}
		},
